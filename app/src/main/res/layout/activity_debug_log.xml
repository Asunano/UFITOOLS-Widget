<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            app:icon="@drawable/ic_arrow_back"
            app:iconTint="@color/text_main" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="调试日志"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_log_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="调试模式: 已启用"
                android:textColor="@color/text_main"
                android:alpha="0.5"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- 操作按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_refresh_log"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="刷新"
            android:textSize="11sp"
            android:textColor="@color/text_main"
            app:icon="@android:drawable/ic_popup_sync"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_log"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="复制全部"
            android:textSize="11sp"
            android:textColor="@color/text_main"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dump_state"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="状态快照"
            android:textSize="11sp"
            android:textColor="@color/text_main"
            app:icon="@android:drawable/ic_menu_info_details"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_log"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="分享"
            android:textSize="11sp"
            android:textColor="@color/text_main"
            app:icon="@android:drawable/ic_menu_share"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_log"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="清空"
            android:textSize="11sp"
            android:textColor="@color/text_main"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp" />
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_sub"
        android:alpha="0.1" />

    <!-- 日志内容区域 -->
    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="horizontal">

            <TextView
                android:id="@+id/tv_log_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="(暂无日志)"
                android:textColor="@color/text_main"
                android:textSize="11sp"
                android:lineSpacingExtra="2dp"
                android:padding="4dp" />

        </HorizontalScrollView>
    </ScrollView>

</LinearLayout>
