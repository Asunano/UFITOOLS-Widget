<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ========== Header 品牌区 ========== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="54dp"
                    android:paddingBottom="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UFITOOLS-Widget"
                        android:textColor="@color/text_main"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="专为 UFI 随身WiFi 打造的桌面小组件"
                        android:textColor="@color/text_main"
                        android:alpha="0.45"
                        android:textSize="13sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- ========== 配置卡片 ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:orientation="vertical"
                android:background="@drawable/bg_widget_card"
                android:padding="24dp">

                <!-- 设备地址 -->
                <include
                    layout="@layout/layout_common_input_field"
                    android:id="@+id/item_device_address" />

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="@color/text_sub"
                    android:alpha="0.1" />

                <!-- 认证口令 -->
                <include
                    layout="@layout/layout_common_input_field"
                    android:id="@+id/item_token" />

                <!-- 保存按钮 -->
                <include
                    layout="@layout/layout_common_action_button"
                    android:id="@+id/btn_setup_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="32dp" />

                <!-- 跳过按钮 -->
                <TextView
                    android:id="@+id/tv_skip"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="暂时跳过，使用默认配置"
                    android:textColor="@color/text_sub"
                    android:textSize="13sp"
                    android:alpha="0.6"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
